{
  "name": "server-workspace",
  "displayName": "Server Workspace",
  "description": "A small Remote-SSH workspace helper for system notes, server file tracking, and basic system information.",
  "version": "0.2.0",
  "publisher": "ArbtoS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ArbtoS/SSH-Server-Workspace.git"
  },
  "bugs": {
    "url": "https://github.com/ArbtoS/SSH-Server-Workspace/issues"
  },
  "homepage": "https://github.com/ArbtoS/SSH-Server-Workspace#readme",
  "keywords": [
    "remote-ssh",
    "server",
    "workspace",
    "notes",
    "linux"
  ],
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "galleryBanner": {
    "color": "#101820",
    "theme": "dark"
  },
  "main": "./out/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onView:serverWorkspace.actions",
    "onView:serverWorkspace.work",
    "onView:serverWorkspace.system",
    "onView:serverWorkspace.notes",
    "onCommand:serverWorkspace.initialize",
    "onCommand:serverWorkspace.refresh",
    "onCommand:serverWorkspace.recreateData",
    "onCommand:serverWorkspace.openNotes",
    "onCommand:serverWorkspace.addNote",
    "onCommand:serverWorkspace.openSystemStatus",
    "onCommand:serverWorkspace.openFile",
    "onCommand:serverWorkspace.trackCurrentFile",
    "onCommand:serverWorkspace.trackPath",
    "onCommand:serverWorkspace.editDisplayName",
    "onCommand:serverWorkspace.clearDisplayName",
    "onCommand:serverWorkspace.editComment",
    "onCommand:serverWorkspace.deleteComment",
    "onCommand:serverWorkspace.copyPath",
    "onCommand:serverWorkspace.updateMetadata"
  ],
  "contributes": {
    "commands": [
      {
        "command": "serverWorkspace.initialize",
        "title": "Server Workspace: Initialisieren"
      },
      {
        "command": "serverWorkspace.refresh",
        "title": "Server Workspace: Aktualisieren"
      },
      {
        "command": "serverWorkspace.recreateData",
        "title": "Server Workspace: Daten neu erstellen"
      },
      {
        "command": "serverWorkspace.openNotes",
        "title": "Server Workspace: Notizen oeffnen"
      },
      {
        "command": "serverWorkspace.addNote",
        "title": "Server Workspace: Notiz hinzufuegen"
      },
      {
        "command": "serverWorkspace.openSystemStatus",
        "title": "Server Workspace: Systemstatus oeffnen"
      },
      {
        "command": "serverWorkspace.openFile",
        "title": "Server Workspace: Datei oeffnen"
      },
      {
        "command": "serverWorkspace.trackCurrentFile",
        "title": "Server Workspace: Aktuelle Datei tracken"
      },
      {
        "command": "serverWorkspace.trackPath",
        "title": "Server Workspace: Pfad tracken"
      },
      {
        "command": "serverWorkspace.editDisplayName",
        "title": "Server Workspace: Klarname bearbeiten"
      },
      {
        "command": "serverWorkspace.clearDisplayName",
        "title": "Server Workspace: Klarname loeschen"
      },
      {
        "command": "serverWorkspace.editComment",
        "title": "Server Workspace: Kommentar bearbeiten"
      },
      {
        "command": "serverWorkspace.deleteComment",
        "title": "Server Workspace: Kommentar loeschen"
      },
      {
        "command": "serverWorkspace.copyPath",
        "title": "Server Workspace: Pfad kopieren"
      },
      {
        "command": "serverWorkspace.updateMetadata",
        "title": "Server Workspace: Metadaten aktualisieren"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "serverWorkspace",
          "title": "Server Workspace",
          "icon": "resources/server-workspace.svg"
        }
      ]
    },
    "views": {
      "serverWorkspace": [
        {
          "id": "serverWorkspace.actions",
          "name": "Aktionen"
        },
        {
          "id": "serverWorkspace.work",
          "name": "Arbeitsseite"
        },
        {
          "id": "serverWorkspace.system",
          "name": "System"
        },
        {
          "id": "serverWorkspace.notes",
          "name": "Notizen"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "serverWorkspace.openFile",
          "when": "false"
        },
        {
          "command": "serverWorkspace.copyPath",
          "when": "false"
        },
        {
          "command": "serverWorkspace.deleteComment",
          "when": "false"
        },
        {
          "command": "serverWorkspace.editDisplayName",
          "when": "false"
        },
        {
          "command": "serverWorkspace.clearDisplayName",
          "when": "false"
        },
        {
          "command": "serverWorkspace.openSystemStatus",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "serverWorkspace.openFile",
          "when": "view == serverWorkspace.work && viewItem == trackedFile",
          "group": "inline@1"
        },
        {
          "command": "serverWorkspace.editComment",
          "when": "view == serverWorkspace.work && viewItem == trackedFile",
          "group": "2_edit@3"
        },
        {
          "command": "serverWorkspace.deleteComment",
          "when": "view == serverWorkspace.work && viewItem == trackedFile",
          "group": "2_edit@4"
        },
        {
          "command": "serverWorkspace.editDisplayName",
          "when": "view == serverWorkspace.work && viewItem == trackedFile",
          "group": "2_edit@1"
        },
        {
          "command": "serverWorkspace.clearDisplayName",
          "when": "view == serverWorkspace.work && viewItem == trackedFile",
          "group": "2_edit@2"
        },
        {
          "command": "serverWorkspace.copyPath",
          "when": "view == serverWorkspace.work && viewItem == trackedFile",
          "group": "3_copy@1"
        },
        {
          "command": "serverWorkspace.updateMetadata",
          "when": "view == serverWorkspace.work && viewItem == trackedFile",
          "group": "4_refresh@1"
        },
        {
          "command": "serverWorkspace.openFile",
          "when": "view == serverWorkspace.work && viewItem == logEntry",
          "group": "inline@1"
        }
      ]
    },
    "configuration": {
      "title": "Server Workspace",
      "properties": {
        "serverWorkspace.language": {
          "type": "string",
          "default": "de",
          "enum": [
            "de",
            "en"
          ],
          "enumDescriptions": [
            "Deutsch",
            "English"
          ],
          "description": "Language for Server Workspace tree view labels, prompts, and notifications. Manifest-provided view names and command titles require a window reload and may still follow VS Code's static extension manifest handling."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "vsce package --out server-workspace-0.2.0.vsix",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.92.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.4.5"
  }
}
