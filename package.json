{
  "name": "ssh-workspace",
  "displayName": "SSH Workspace",
  "description": "A small Remote-SSH workspace helper for system notes, server file tracking, and basic system information.",
  "version": "0.3.3",
  "publisher": "ArbtoS",
  "license": "MIT",
  "icon": "resources/ssh-workspace.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ArbtoS/SSH-Workspace.git"
  },
  "bugs": {
    "url": "https://github.com/ArbtoS/SSH-Workspace/issues"
  },
  "homepage": "https://github.com/ArbtoS/SSH-Workspace#readme",
  "keywords": [
    "remote-ssh",
    "server",
    "workspace",
    "notes",
    "linux"
  ],
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "galleryBanner": {
    "color": "#101820",
    "theme": "dark"
  },
  "main": "./out/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onView:sshWorkspace.actions",
    "onView:sshWorkspace.work",
    "onView:sshWorkspace.system",
    "onView:sshWorkspace.notes",
    "onCommand:sshWorkspace.initialize",
    "onCommand:sshWorkspace.refresh",
    "onCommand:sshWorkspace.recreateData",
    "onCommand:sshWorkspace.openNotes",
    "onCommand:sshWorkspace.addNote",
    "onCommand:sshWorkspace.openSystemStatus",
    "onCommand:sshWorkspace.openFile",
    "onCommand:sshWorkspace.trackCurrentFile",
    "onCommand:sshWorkspace.trackPath",
    "onCommand:sshWorkspace.editDisplayName",
    "onCommand:sshWorkspace.clearDisplayName",
    "onCommand:sshWorkspace.editComment",
    "onCommand:sshWorkspace.deleteComment",
    "onCommand:sshWorkspace.editControlCommands",
    "onCommand:sshWorkspace.addExtraCommand",
    "onCommand:sshWorkspace.removeExtraCommand",
    "onCommand:sshWorkspace.runExtraCommand",
    "onCommand:sshWorkspace.startFileAction",
    "onCommand:sshWorkspace.stopFileAction",
    "onCommand:sshWorkspace.restartFileAction",
    "onCommand:sshWorkspace.statusFileAction",
    "onCommand:sshWorkspace.copyPath",
    "onCommand:sshWorkspace.updateMetadata"
  ],
  "contributes": {
    "commands": [
      {
        "command": "sshWorkspace.initialize",
        "title": "SSH Workspace: Initialisieren"
      },
      {
        "command": "sshWorkspace.refresh",
        "title": "SSH Workspace: Aktualisieren"
      },
      {
        "command": "sshWorkspace.recreateData",
        "title": "SSH Workspace: Daten neu erstellen"
      },
      {
        "command": "sshWorkspace.openNotes",
        "title": "SSH Workspace: Notizen oeffnen"
      },
      {
        "command": "sshWorkspace.addNote",
        "title": "SSH Workspace: Notiz hinzufuegen"
      },
      {
        "command": "sshWorkspace.openSystemStatus",
        "title": "SSH Workspace: Systemstatus oeffnen"
      },
      {
        "command": "sshWorkspace.openFile",
        "title": "SSH Workspace: Datei oeffnen"
      },
      {
        "command": "sshWorkspace.trackCurrentFile",
        "title": "SSH Workspace: Aktuelle Datei tracken"
      },
      {
        "command": "sshWorkspace.trackPath",
        "title": "SSH Workspace: Pfad tracken"
      },
      {
        "command": "sshWorkspace.editDisplayName",
        "title": "SSH Workspace: Klarname bearbeiten"
      },
      {
        "command": "sshWorkspace.clearDisplayName",
        "title": "SSH Workspace: Klarname loeschen"
      },
      {
        "command": "sshWorkspace.editComment",
        "title": "SSH Workspace: Kommentar bearbeiten"
      },
      {
        "command": "sshWorkspace.deleteComment",
        "title": "SSH Workspace: Kommentar loeschen"
      },
      {
        "command": "sshWorkspace.editControlCommands",
        "title": "SSH Workspace: Service bearbeiten"
      },
      {
        "command": "sshWorkspace.addExtraCommand",
        "title": "SSH Workspace: Zusatzbefehl hinzufuegen"
      },
      {
        "command": "sshWorkspace.removeExtraCommand",
        "title": "SSH Workspace: Zusatzbefehl entfernen"
      },
      {
        "command": "sshWorkspace.runExtraCommand",
        "title": "SSH Workspace: Zusatzbefehl ausfuehren"
      },
      {
        "command": "sshWorkspace.startFileAction",
        "title": "SSH Workspace: Datei starten"
      },
      {
        "command": "sshWorkspace.stopFileAction",
        "title": "SSH Workspace: Datei stoppen"
      },
      {
        "command": "sshWorkspace.restartFileAction",
        "title": "SSH Workspace: Datei neustarten"
      },
      {
        "command": "sshWorkspace.statusFileAction",
        "title": "SSH Workspace: Datei-Status abrufen"
      },
      {
        "command": "sshWorkspace.copyPath",
        "title": "SSH Workspace: Pfad kopieren"
      },
      {
        "command": "sshWorkspace.updateMetadata",
        "title": "SSH Workspace: Metadaten aktualisieren"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sshWorkspace",
          "title": "SSH Workspace",
          "icon": "resources/ssh-workspace.svg"
        }
      ]
    },
    "views": {
      "sshWorkspace": [
        {
          "id": "sshWorkspace.actions",
          "name": "Aktionen"
        },
        {
          "id": "sshWorkspace.work",
          "name": "Arbeitsseite"
        },
        {
          "id": "sshWorkspace.system",
          "name": "System"
        },
        {
          "id": "sshWorkspace.notes",
          "name": "Notizen"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "sshWorkspace.openFile",
          "when": "false"
        },
        {
          "command": "sshWorkspace.copyPath",
          "when": "false"
        },
        {
          "command": "sshWorkspace.deleteComment",
          "when": "false"
        },
        {
          "command": "sshWorkspace.editControlCommands",
          "when": "false"
        },
        {
          "command": "sshWorkspace.addExtraCommand",
          "when": "false"
        },
        {
          "command": "sshWorkspace.removeExtraCommand",
          "when": "false"
        },
        {
          "command": "sshWorkspace.runExtraCommand",
          "when": "false"
        },
        {
          "command": "sshWorkspace.startFileAction",
          "when": "false"
        },
        {
          "command": "sshWorkspace.stopFileAction",
          "when": "false"
        },
        {
          "command": "sshWorkspace.restartFileAction",
          "when": "false"
        },
        {
          "command": "sshWorkspace.statusFileAction",
          "when": "false"
        },
        {
          "command": "sshWorkspace.editDisplayName",
          "when": "false"
        },
        {
          "command": "sshWorkspace.clearDisplayName",
          "when": "false"
        },
        {
          "command": "sshWorkspace.openSystemStatus",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "sshWorkspace.openFile",
          "when": "view == sshWorkspace.work && viewItem == trackedFile",
          "group": "inline@1"
        },
        {
          "command": "sshWorkspace.editComment",
          "when": "view == sshWorkspace.work && viewItem == trackedFile",
          "group": "2_edit@3"
        },
        {
          "command": "sshWorkspace.deleteComment",
          "when": "view == sshWorkspace.work && viewItem == trackedFile",
          "group": "2_edit@4"
        },
        {
          "command": "sshWorkspace.editDisplayName",
          "when": "view == sshWorkspace.work && viewItem == trackedFile",
          "group": "2_edit@1"
        },
        {
          "command": "sshWorkspace.clearDisplayName",
          "when": "view == sshWorkspace.work && viewItem == trackedFile",
          "group": "2_edit@2"
        },
        {
          "command": "sshWorkspace.copyPath",
          "when": "view == sshWorkspace.work && viewItem == trackedFile",
          "group": "3_copy@1"
        },
        {
          "command": "sshWorkspace.editControlCommands",
          "when": "view == sshWorkspace.work && viewItem == trackedFile",
          "group": "4_actions@1"
        },
        {
          "command": "sshWorkspace.addExtraCommand",
          "when": "view == sshWorkspace.work && viewItem == trackedFile",
          "group": "4_actions@6"
        },
        {
          "command": "sshWorkspace.startFileAction",
          "when": "view == sshWorkspace.work && viewItem == trackedFile",
          "group": "4_actions@2"
        },
        {
          "command": "sshWorkspace.stopFileAction",
          "when": "view == sshWorkspace.work && viewItem == trackedFile",
          "group": "4_actions@3"
        },
        {
          "command": "sshWorkspace.restartFileAction",
          "when": "view == sshWorkspace.work && viewItem == trackedFile",
          "group": "4_actions@4"
        },
        {
          "command": "sshWorkspace.statusFileAction",
          "when": "view == sshWorkspace.work && viewItem == trackedFile",
          "group": "4_actions@5"
        },
        {
          "command": "sshWorkspace.updateMetadata",
          "when": "view == sshWorkspace.work && viewItem == trackedFile",
          "group": "5_refresh@1"
        },
        {
          "command": "sshWorkspace.openFile",
          "when": "view == sshWorkspace.work && viewItem == logEntry",
          "group": "inline@1"
        },
        {
          "command": "sshWorkspace.runExtraCommand",
          "when": "view == sshWorkspace.work && viewItem == extraFileAction",
          "group": "inline@1"
        },
        {
          "command": "sshWorkspace.removeExtraCommand",
          "when": "view == sshWorkspace.work && viewItem == extraFileAction",
          "group": "2_edit@1"
        }
      ]
    },
    "configuration": {
      "title": "SSH Workspace",
      "properties": {
        "sshWorkspace.language": {
          "type": "string",
          "default": "de",
          "enum": [
            "de",
            "en"
          ],
          "enumDescriptions": [
            "Deutsch",
            "English"
          ],
          "description": "Language for SSH Workspace tree view labels, prompts, and notifications. Manifest-provided view names and command titles require a window reload and may still follow VS Code's static extension manifest handling."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "vsce package --out ssh-workspace-0.3.3.vsix",
    "publish:marketplace": "vsce publish",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.92.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.4.5"
  }
}
