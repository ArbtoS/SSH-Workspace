{
  "name": "ssh-server-workspace",
  "displayName": "SSH Server Workspace",
  "description": "A small Remote-SSH workspace helper for system notes, server file tracking, and basic system information.",
  "version": "0.2.1",
  "publisher": "ArbtoS",
  "license": "MIT",
  "icon": "resources/ssh-server-workspace.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ArbtoS/SSH-Server-Workspace.git"
  },
  "bugs": {
    "url": "https://github.com/ArbtoS/SSH-Server-Workspace/issues"
  },
  "homepage": "https://github.com/ArbtoS/SSH-Server-Workspace#readme",
  "keywords": [
    "remote-ssh",
    "server",
    "workspace",
    "notes",
    "linux"
  ],
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "galleryBanner": {
    "color": "#101820",
    "theme": "dark"
  },
  "main": "./out/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onView:sshServerWorkspace.actions",
    "onView:sshServerWorkspace.work",
    "onView:sshServerWorkspace.system",
    "onView:sshServerWorkspace.notes",
    "onCommand:sshServerWorkspace.initialize",
    "onCommand:sshServerWorkspace.refresh",
    "onCommand:sshServerWorkspace.recreateData",
    "onCommand:sshServerWorkspace.openNotes",
    "onCommand:sshServerWorkspace.addNote",
    "onCommand:sshServerWorkspace.openSystemStatus",
    "onCommand:sshServerWorkspace.openFile",
    "onCommand:sshServerWorkspace.trackCurrentFile",
    "onCommand:sshServerWorkspace.trackPath",
    "onCommand:sshServerWorkspace.editDisplayName",
    "onCommand:sshServerWorkspace.clearDisplayName",
    "onCommand:sshServerWorkspace.editComment",
    "onCommand:sshServerWorkspace.deleteComment",
    "onCommand:sshServerWorkspace.editControlCommands",
    "onCommand:sshServerWorkspace.startFileAction",
    "onCommand:sshServerWorkspace.stopFileAction",
    "onCommand:sshServerWorkspace.restartFileAction",
    "onCommand:sshServerWorkspace.copyPath",
    "onCommand:sshServerWorkspace.updateMetadata"
  ],
  "contributes": {
    "commands": [
      {
        "command": "sshServerWorkspace.initialize",
        "title": "SSH Server Workspace: Initialisieren"
      },
      {
        "command": "sshServerWorkspace.refresh",
        "title": "SSH Server Workspace: Aktualisieren"
      },
      {
        "command": "sshServerWorkspace.recreateData",
        "title": "SSH Server Workspace: Daten neu erstellen"
      },
      {
        "command": "sshServerWorkspace.openNotes",
        "title": "SSH Server Workspace: Notizen oeffnen"
      },
      {
        "command": "sshServerWorkspace.addNote",
        "title": "SSH Server Workspace: Notiz hinzufuegen"
      },
      {
        "command": "sshServerWorkspace.openSystemStatus",
        "title": "SSH Server Workspace: Systemstatus oeffnen"
      },
      {
        "command": "sshServerWorkspace.openFile",
        "title": "SSH Server Workspace: Datei oeffnen"
      },
      {
        "command": "sshServerWorkspace.trackCurrentFile",
        "title": "SSH Server Workspace: Aktuelle Datei tracken"
      },
      {
        "command": "sshServerWorkspace.trackPath",
        "title": "SSH Server Workspace: Pfad tracken"
      },
      {
        "command": "sshServerWorkspace.editDisplayName",
        "title": "SSH Server Workspace: Klarname bearbeiten"
      },
      {
        "command": "sshServerWorkspace.clearDisplayName",
        "title": "SSH Server Workspace: Klarname loeschen"
      },
      {
        "command": "sshServerWorkspace.editComment",
        "title": "SSH Server Workspace: Kommentar bearbeiten"
      },
      {
        "command": "sshServerWorkspace.deleteComment",
        "title": "SSH Server Workspace: Kommentar loeschen"
      },
      {
        "command": "sshServerWorkspace.editControlCommands",
        "title": "SSH Server Workspace: Start/Stop/Restart bearbeiten"
      },
      {
        "command": "sshServerWorkspace.startFileAction",
        "title": "SSH Server Workspace: Datei starten"
      },
      {
        "command": "sshServerWorkspace.stopFileAction",
        "title": "SSH Server Workspace: Datei stoppen"
      },
      {
        "command": "sshServerWorkspace.restartFileAction",
        "title": "SSH Server Workspace: Datei neustarten"
      },
      {
        "command": "sshServerWorkspace.copyPath",
        "title": "SSH Server Workspace: Pfad kopieren"
      },
      {
        "command": "sshServerWorkspace.updateMetadata",
        "title": "SSH Server Workspace: Metadaten aktualisieren"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sshServerWorkspace",
          "title": "SSH Server Workspace",
          "icon": "resources/ssh-server-workspace.svg"
        }
      ]
    },
    "views": {
      "sshServerWorkspace": [
        {
          "id": "sshServerWorkspace.actions",
          "name": "Aktionen"
        },
        {
          "id": "sshServerWorkspace.work",
          "name": "Arbeitsseite"
        },
        {
          "id": "sshServerWorkspace.system",
          "name": "System"
        },
        {
          "id": "sshServerWorkspace.notes",
          "name": "Notizen"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "sshServerWorkspace.openFile",
          "when": "false"
        },
        {
          "command": "sshServerWorkspace.copyPath",
          "when": "false"
        },
        {
          "command": "sshServerWorkspace.deleteComment",
          "when": "false"
        },
        {
          "command": "sshServerWorkspace.editControlCommands",
          "when": "false"
        },
        {
          "command": "sshServerWorkspace.startFileAction",
          "when": "false"
        },
        {
          "command": "sshServerWorkspace.stopFileAction",
          "when": "false"
        },
        {
          "command": "sshServerWorkspace.restartFileAction",
          "when": "false"
        },
        {
          "command": "sshServerWorkspace.editDisplayName",
          "when": "false"
        },
        {
          "command": "sshServerWorkspace.clearDisplayName",
          "when": "false"
        },
        {
          "command": "sshServerWorkspace.openSystemStatus",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "sshServerWorkspace.openFile",
          "when": "view == sshServerWorkspace.work && viewItem == trackedFile",
          "group": "inline@1"
        },
        {
          "command": "sshServerWorkspace.editComment",
          "when": "view == sshServerWorkspace.work && viewItem == trackedFile",
          "group": "2_edit@3"
        },
        {
          "command": "sshServerWorkspace.deleteComment",
          "when": "view == sshServerWorkspace.work && viewItem == trackedFile",
          "group": "2_edit@4"
        },
        {
          "command": "sshServerWorkspace.editDisplayName",
          "when": "view == sshServerWorkspace.work && viewItem == trackedFile",
          "group": "2_edit@1"
        },
        {
          "command": "sshServerWorkspace.clearDisplayName",
          "when": "view == sshServerWorkspace.work && viewItem == trackedFile",
          "group": "2_edit@2"
        },
        {
          "command": "sshServerWorkspace.copyPath",
          "when": "view == sshServerWorkspace.work && viewItem == trackedFile",
          "group": "3_copy@1"
        },
        {
          "command": "sshServerWorkspace.editControlCommands",
          "when": "view == sshServerWorkspace.work && viewItem == trackedFile",
          "group": "4_actions@1"
        },
        {
          "command": "sshServerWorkspace.startFileAction",
          "when": "view == sshServerWorkspace.work && viewItem == trackedFile",
          "group": "4_actions@2"
        },
        {
          "command": "sshServerWorkspace.stopFileAction",
          "when": "view == sshServerWorkspace.work && viewItem == trackedFile",
          "group": "4_actions@3"
        },
        {
          "command": "sshServerWorkspace.restartFileAction",
          "when": "view == sshServerWorkspace.work && viewItem == trackedFile",
          "group": "4_actions@4"
        },
        {
          "command": "sshServerWorkspace.updateMetadata",
          "when": "view == sshServerWorkspace.work && viewItem == trackedFile",
          "group": "5_refresh@1"
        },
        {
          "command": "sshServerWorkspace.openFile",
          "when": "view == sshServerWorkspace.work && viewItem == logEntry",
          "group": "inline@1"
        }
      ]
    },
    "configuration": {
      "title": "SSH Server Workspace",
      "properties": {
        "sshServerWorkspace.language": {
          "type": "string",
          "default": "de",
          "enum": [
            "de",
            "en"
          ],
          "enumDescriptions": [
            "Deutsch",
            "English"
          ],
          "description": "Language for SSH Server Workspace tree view labels, prompts, and notifications. Manifest-provided view names and command titles require a window reload and may still follow VS Code's static extension manifest handling."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "vsce package --out ssh-server-workspace-0.2.1.vsix",
    "publish:marketplace": "vsce publish",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.92.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.4.5"
  }
}
